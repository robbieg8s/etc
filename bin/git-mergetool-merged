#!/usr/bin/awk -f

# Note: this is buggy if used to merge binary files ...
# You can hack around this by invoking it as (zsh):
# :; git mergetool --tool=merged -- ${(f)"$(git ls-modified)"}
# It should be recast to use the numstat hack to sniff them

# gitconfig to configure this:
#
# [mergetool "merged"]
#   cmd = git mergetool-merged \"${MERGED}\"
#   keepBackup = false
#   trustExitCode = true

/^(((<<<<<<<|>>>>>>>) .*)|=======)$/ {
  ++conflicts
  print FILENAME ":" FNR ": " $0
}
END {
  if (conflicts) {
    print "Found " conflicts " conflict marker(s)"
    exit 1
  }
}
